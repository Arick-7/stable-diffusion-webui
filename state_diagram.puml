@startuml
!theme plain
title 建筑AI系统项目状态图

' 样式定义
skinparam state {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontSize 12
}

skinparam stateArrow {
    FontSize 10
}

[*] --> 项目初始化 : 用户启动系统

state 项目初始化 {
    项目初始化 : 📋 收集基本信息
    项目初始化 : 🔍 验证输入数据
    项目初始化 : 📊 初始化项目模型
}

项目初始化 --> 数据收集 : 基本信息完整

state 数据收集 {
    数据收集 : 📚 加载历史项目数据
    数据收集 : 📏 获取建设标准
    数据收集 : 🤖 启动AI模型
    --
    state 数据验证 {
        数据验证 : 检查数据完整性
        数据验证 : 验证数据有效性
    }
}

数据收集 --> 智能对话 : 数据准备完成
数据收集 --> 数据补充 : [数据不完整]

state 数据补充 {
    数据补充 : ❓ 生成补充问题
    数据补充 : 📝 等待用户输入
    数据补充 : ✅ 验证补充信息
}

数据补充 --> 数据收集 : 信息补充完成
数据补充 --> 项目暂停 : [用户取消]

state 智能对话 {
    智能对话 : 🗣️ AI生成专业问题
    智能对话 : 👂 接收用户回答
    智能对话 : 🧠 更新需求模型
    智能对话 : 📊 评估信息完整度
    --
    state 对话循环 {
        对话循环 : while(完整度<80%)
    }
}

智能对话 --> 需求分析 : 信息收集完成(>=80%)
智能对话 --> 智能对话 : [继续对话]

state 需求分析 {
    需求分析 : 🔍 分析项目需求
    需求分析 : ⚖️ 识别约束条件
    需求分析 : 🎯 确定项目目标
    需求分析 : 📈 制定KPI指标
}

需求分析 --> 文档生成 : 需求分析完成

state 文档生成 {
    state 并行生成 {
        --
        策划书生成 : 📄 生成项目策划书
        任务书生成 : 📋 生成设计任务书  
        指标分析 : 📊 生成KPI分析报告
        --
    }
    
    state KPI详细分析 {
        能耗分析 : 🔋 能耗性能分析
        可持续性分析 : 🌱 可持续性评估
        舒适度分析 : 🏠 舒适度指标
        经济分析 : 💰 经济性分析
        安全分析 : 🛡️ 安全性评估
    }
}

文档生成 --> 质量检查 : 文档生成完成

state 质量检查 {
    质量检查 : 🔍 内容完整性检查
    质量检查 : 📏 标准合规性验证
    质量检查 : 💡 技术可行性评估
    质量检查 : 📊 质量评分计算
}

质量检查 --> 文档优化 : [质量不达标]
质量检查 --> 最终审核 : [质量达标]

state 文档优化 {
    文档优化 : 🔧 识别改进点
    文档优化 : 💡 生成优化建议
    文档优化 : 📝 应用改进方案
    文档优化 : 🔄 重新生成文档
}

文档优化 --> 质量检查 : 优化完成

state 最终审核 {
    最终审核 : 👥 专家审核
    最终审核 : ✅ 业主确认
    最终审核 : 📋 审核记录
}

最终审核 --> 文档交付 : [审核通过]
最终审核 --> 文档优化 : [需要修改]

state 文档交付 {
    文档交付 : 📄 生成PDF文档
    文档交付 : 💾 保存项目记录
    文档交付 : 📧 发送交付通知
    文档交付 : 📊 更新统计数据
}

文档交付 --> 项目完成 : 交付成功

state 项目完成 {
    项目完成 : ✅ 项目状态更新
    项目完成 : 📈 经验数据入库
    项目完成 : 🎯 价值实现统计
}

项目完成 --> [*] : 系统关闭

' 异常状态
state 项目暂停 {
    项目暂停 : ⏸️ 保存当前状态
    项目暂停 : 💾 数据持久化
}

state 系统错误 {
    系统错误 : ❌ 错误处理
    系统错误 : 🔄 尝试恢复
    系统错误 : 📝 记录错误日志
}

项目暂停 --> 数据收集 : 用户恢复操作
项目暂停 --> [*] : 用户放弃项目

' 任何状态都可能发生系统错误
数据收集 --> 系统错误 : [系统异常]
智能对话 --> 系统错误 : [系统异常] 
需求分析 --> 系统错误 : [系统异常]
文档生成 --> 系统错误 : [系统异常]
质量检查 --> 系统错误 : [系统异常]

系统错误 --> 项目初始化 : 恢复成功
系统错误 --> [*] : 无法恢复

' 状态注释
note right of 智能对话
    核心交互阶段
    通过AI对话收集
    完整的项目需求
end note

note left of 文档生成
    并行处理多个文档
    确保生成效率
    和内容一致性
end note

note bottom of 质量检查
    多维度质量控制：
    ✓ 内容完整性
    ✓ 标准合规性  
    ✓ 技术可行性
    ✓ 经济合理性
end note

@enduml